# Auto detect text files and normalize line endings to LF
* text=auto

# Java source files
*.java text eol=lf

# Gradle & Build configuration
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradlew text eol=lf
*.sh text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.properties text eol=lf

# Markdown & Documentation
*.md text eol=lf
*.txt text eol=lf

# Scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# HTML & Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Binary files
*.jar binary
*.war binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ttf binary
*.otf binary
*.eot binary
*.woff binary
*.woff2 binary

# Keep CRLF for Windows batch scripts
*.bat text eol=crlf
*.cmd text eol=crlf
