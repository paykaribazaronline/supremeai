# GitReverse Environment Variables
# Copy this file to .env.local and fill in your values

# LLM Provider (at least one required)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.5-pro
GOOGLE_GENERATIVE_AI_API_KEY=...
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-pro

# GitHub (optional, for higher rate limits)
GITHUB_TOKEN=ghp_...

# Supabase (all optional)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Server-side only, do not expose

# Custom Reverse Service
CUSTOM_REVERSE_SERVICE_URL=http://localhost:3001

# View Counter
VIEWS_IP_SALT=random-salt-string-here

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
