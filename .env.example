# .env.example - Complete Template
# =================================

# === JWT Configuration ===
JWT_SECRET=your-256-bit-secret-key-minimum-32-characters-long
JWT_EXPIRATION=86400000
BOOTSTRAP_TOKEN=your-bootstrap-token-for-first-time-setup

# === Firebase ===
FIREBASE_SERVICE_ACCOUNT=path/to/service-account.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# === AI Provider API Keys (11 total) ===
# Minimum 3 required for basic operation
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
COHERE_API_KEY=your-cohere-key
PERPLEXITY_API_KEY=pplx-your-perplexity-key
MISTRAL_API_KEY=your-mistral-key
LLAMA_API_KEY=your-llama-key
DEEPSEEK_API_KEY=your-deepseek-key
GROK_API_KEY=your-grok-key
AZURE_OPENAI_API_KEY=your-azure-key
CUSTOM_AI_API_KEY=your-custom-key

# === Database ===
DB_URL=jdbc:postgresql://localhost:5432/supremeai
DB_USERNAME=admin
DB_PASSWORD=your-db-password
DB_POOL_MAX=50
DB_POOL_MIN=10
DB_TIMEOUT=20000

# === Redis (NEW) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# === Server ===
SERVER_PORT=8080
ADMIN_PORT=8001
MONITORING_PORT=8000
