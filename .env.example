# SupremeAI 2.0 Environment Configuration
# Copy this file to .env and fill in your values

# Core
APP_NAME="SupremeAI 2.0"
ENV=local
DEBUG=true
PORT=8000
HOST=0.0.0.0

# AI Providers
OPENROUTER_API_KEY=
HF_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
FIRECRAWL_API_KEY=
OLLAMA_URL=http://localhost:11434

# Monitoring
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=

# Cloud
GCP_CLOUD_RUN_URL=
GCP_REGION=us-central1
GCP_SERVICE_NAME=supremeai-api
GCP_PROJECT_ID=
GCP_FIRESTORE_COLLECTION=verification_queue
GCP_FIRESTORE_SQLITE_PATH=
GCP_PUBSUB_TOPIC=supremeai-tasks
GCP_PUBSUB_SUBSCRIPTION=
GCP_PUBSUB_SQLITE_PATH=

# Multi-cloud
RAILWAY_URL=
RENDER_URL=
REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_URL=

# Admin
SUPREMEAI_ADMIN_PASSWORD_HASH=
ADMIN_RULES_DB=data/constitutional_rules.db

# Limits
MAX_COST_PER_TASK=0.01
