# ============================================================================
# SUPREMEAI CONFIGURATION FILE (.env.example)
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to git (already in .gitignore)
# 4. Use for development, testing, and local runs
# 5. For CI/CD, use GitHub Secrets instead
# 6. For local Google/Firebase auth, prefer ADC: gcloud auth application-default login
# ============================================================================

# ========================================
# FIREBASE CONFIGURATION
# ========================================
# Firebase project settings
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Preferred local auth: use ADC instead of storing a short-lived access token in .env
# Optional explicit credential override for local scripts
FIREBASE_CREDENTIALS_FILE=./secrets/service-account.json

# Service account (base64 encoded for GitHub Actions)
# Generate: cat service-account.json | base64
FIREBASE_SERVICE_ACCOUNT=your_base64_encoded_service_account_json

# Firebase API key (for web app)
FIREBASE_API_KEY=your-firebase-web-api-key

# ========================================
# LLM PROVIDERS
# ========================================
# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek (Alternative provider)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# ========================================
# NOTIFICATION CHANNELS
# ========================================
# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts

# Discord webhook for notifications
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR/WEBHOOK/URL
DISCORD_CHANNEL=alerts

# Twilio SMS (for critical alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email configuration (SendGrid or similar)
MAIL_API_KEY=your-sendgrid-api-key
MAIL_FROM_ADDRESS=noreply@supremeai.example.com
MAIL_FROM_NAME=SupremeAI Notifications

# ========================================
# GOOGLE CLOUD
# ========================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Cloud Build
CLOUD_BUILD_TRIGGER_ID=your-trigger-id

# ========================================
# APPLICATION CONFIG
# ========================================
# Server configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/
SPRING_PROFILES_ACTIVE=development

# Database
DATABASE_URL=jdbc:mysql://localhost:3306/supremeai
DATABASE_USERNAME=root
DATABASE_PASSWORD=your-db-password

# ========================================
# SECURITY & SECRETS
# ========================================
# Secret manager backend: env | gcp | aws | azure | vault
SECRET_MANAGER_BACKEND=env
GCP_SECRET_LOCATION=global
AZURE_KEY_VAULT_URL=

# Key rotation and admin mode flags
KEY_ROTATION_ENABLED=true
KING_MODE_ENABLED=true

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Admin API key for system operations
ADMIN_API_KEY=your-admin-api-key-for-protected-endpoints

# Admin bootstrap/login credentials for local scripts
SUPREMEAI_ADMIN_USERNAME=supremeai
SUPREMEAI_ADMIN_EMAIL=admin@supremeai.com
SUPREMEAI_ADMIN_PASSWORD=your-strong-admin-password

# ========================================
# DEPLOYMENT TARGETS
# ========================================
# Render deployment
RENDER_API_KEY=your-render-api-key
RENDER_SERVICE_ID=your-render-service-id

# ========================================
# LOGGING & MONITORING
# ========================================
# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Metrics export
METRICS_EXPORT_ENABLED=true
METRICS_EXPORT_INTERVAL_SECONDS=60

# ========================================
# FEATURE FLAGS
# ========================================
# Enable/disable features
FEATURE_WEBSOCKET_ENABLED=true
FEATURE_ANALYTICS_PERSISTENCE_ENABLED=true
FEATURE_ML_INTELLIGENCE_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true

# ========================================
# DEVELOPMENT ONLY
# ========================================
# Enable verbose logging in development
DEBUG_MODE=false

# Mock external services (for testing without real credentials)
MOCK_EXTERNAL_SERVICES=false

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================

# GitHub App Authentication (RECOMMENDED)
# Install app from: https://github.com/apps/supremeai-bot
# Provides 10,000 req/hour rate limit + better security
GITHUB_APP_ID=your-app-id-from-github
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYour\nPrivate\nKey\nHere\n-----END RSA PRIVATE KEY-----
GITHUB_APP_INSTALLATION_ID=your-installation-id

# GitHub Webhook Security
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Legacy personal access token (optional – use GitHub App instead)
# GITHUB_TOKEN=ghp_your_github_token_here
# GITHUB_USERNAME=your_github_username

# GitHub API Configuration
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_TIMEOUT_SECONDS=30

# Test Repository (for initial setup & verification)
TEST_REPO_OWNER=paykaribazaronline
TEST_REPO_NAME=supremeai

# ============================================================================
# SELF-HEALING SYSTEM CONFIGURATION
# ============================================================================

# Circuit Breaker (Retry Limiter)
# Max consecutive failures before escalating to human
HEALING_CIRCUIT_BREAKER_MAX_FAILURES=3
# Cooldown period after circuit opens (minutes)
HEALING_CIRCUIT_BREAKER_COOLDOWN_MINUTES=30

# Healing Loop Settings
# Maximum retry attempts per workflow failure
HEALING_MAX_RETRIES=3
# Initial backoff delay (minutes) - increases exponentially
HEALING_RETRY_BACKOFF_MINUTES=1
# Time to wait before checking workflow result (ms)
HEALING_WORKFLOW_CHECK_DELAY_MS=300000

# Rate Limiter (GitHub API Protection)
# Maximum requests per hour (GitHub App limit is 10,000, be conservative)
RATE_LIMITER_MAX_REQUESTS_PER_HOUR=4500

# Validation Pipeline Thresholds
# Minimum confidence score for deploying fixes (0.0 to 1.0)
VALIDATION_MIN_CONFIDENCE_SCORE=0.85
# Maximum lines of code changes before requiring human review
VALIDATION_MAX_LINES_CHANGED=50

# Watchdog Service (External System Monitor)
# Check interval for healing system health (seconds)
WATCHDOG_CHECK_INTERVAL_SECONDS=60
# Number of failures to trigger alert
WATCHDOG_FAILURE_THRESHOLD=5
# Time window for failure threshold check (minutes)
WATCHDOG_CHECK_WINDOW_MINUTES=10
# Enable automatic disabling of healing on system failure
WATCHDOG_AUTO_DISABLE_ENABLED=true

# Escalation Channels
# PagerDuty incident creation
PAGERDUTY_API_KEY=u+your-pagerduty-api-key
PAGERDUTY_ROUTING_KEY=Pyour-routing-key

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ADMIN_CHANNEL=#alerts
SLACK_HEALING_CHANNEL=#ci-cd-healing

# Admin Contact
ADMIN_EMAIL=admin@company.com
ADMIN_SLACK_USER_ID=U00000000

# ============================================================================
# FIRESTORE COLLECTIONS FOR HEALING
# ============================================================================
# Enable persistence of healing attempts to Firestore
FIRESTORE_HEALING_ENABLED=true
# Collection names (don't usually need to change)
FIRESTORE_COLLECTION_HEALING_ATTEMPTS=healing_attempts
FIRESTORE_COLLECTION_ERROR_PATTERNS=error_patterns
GITHUB_REPO=paykaribazaronline/supremeai
GITHUB_ORG=paykaribazaronline

# ============================================================================
# GITHUB APP — SupremeAI Bot
# https://github.com/apps/supremeai-bot
# ============================================================================
# Public identifiers (safe to keep in example file)
GITHUB_APP_ID=3300194
GITHUB_APP_CLIENT_ID=Iv23liZY31q8QhovvzQt
GITHUB_APP_NAME=SupremeAI Bot

# Installation ID — visible in URL when you click Configure:
#   github.com/settings/installations/121998309
GITHUB_APP_INSTALLATION_ID=121998309

# Webhook URL — set to your custom domain (njel.com.bd) backed by Cloud Run.
# Cloud Run service: supremeai  |  Project: supremeai-a  |  Region: us-central1
# Cloud Run fallback: https://supremeai-<hash>-uc.a.run.app/webhook/github
GITHUB_APP_WEBHOOK_URL=https://njel.com.bd/webhook/github

# Webhook secret — NEVER commit the real value here (public repo).
# Set this ONLY in:
#   1. Your actual .env file (local dev), OR
#   2. GitHub → Repo Settings → Secrets → Actions → GITHUB_APP_WEBHOOK_SECRET
# The secret configured on the GitHub App settings page is: (store in GitHub Secrets)
GITHUB_APP_WEBHOOK_SECRET=your_webhook_secret_here

# ── Private key (choose ONE of the two options below) ────────────────────────
#
# OPTION A — File path (desktop/server, when you can upload .pem)
#   1. Download from: GitHub App settings → Private keys → Generate a private key
#   2. Save as: secrets/supremeai-bot.pem  (folder is gitignored)
#   3. Set the path:
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/supremeai-bot.pem
#
# OPTION B — Base64 env var (MOBILE-FRIENDLY — no file upload needed)
#   Use this when you cannot transfer a .pem file (e.g. from mobile).
#   Steps (do this from any desktop browser or GitHub Codespaces once):
#   1. Open the downloaded .pem file in any text editor
#   2. Copy ALL the text (including -----BEGIN/END RSA PRIVATE KEY----- lines)
#   3. Base64-encode it:
#      Linux/Mac:  cat supremeai-bot.pem | base64 -w 0
#      Windows:    certutil -encode supremeai-bot.pem tmp.b64 && type tmp.b64
#   4. Paste the base64 output as the value below (or into GitHub Secret)
GITHUB_APP_PRIVATE_KEY_BASE64=your_base64_encoded_pem_content_here
#   The app will prefer GITHUB_APP_PRIVATE_KEY_BASE64 if GITHUB_APP_PRIVATE_KEY_PATH is missing.
# ─────────────────────────────────────────────────────────────────────────────

# Client secret — generate from GitHub App settings → Client secrets → "Generate a new client secret"
# Required only if you use OAuth / user-authorization flows.
GITHUB_APP_CLIENT_SECRET=your_github_app_client_secret_here

# ============================================================================
# AI API PROVIDERS (configure 0..n providers for the consensus system)
# ============================================================================
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
GOOGLE_GEMINI_API_KEY=your_gemini_key_here
META_API_KEY=your_meta_key_here
MISTRAL_API_KEY=your_mistral_key_here
COHERE_API_KEY=your_cohere_key_here
HUGGINGFACE_API_KEY=your_huggingface_key_here
XAI_GROK_API_KEY=your_xai_key_here
DEEPSEEK_API_KEY_CONSENSUS=your_deepseek_key_here
PERPLEXITY_API_KEY=your_perplexity_key_here

# ============================================================================
# CLOUD PLATFORMS
# ============================================================================
# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=supremeai-bucket

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_TENANT_ID=your_tenant_id_here
AZURE_CLIENT_ID=your_client_id_here
AZURE_CLIENT_SECRET=your_client_secret_here

# ============================================================================
# DOCKER & CONTAINER REGISTRY
# ============================================================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password
DOCKER_IMAGE_NAME=supremeai

# ============================================================================
# SECRET FILES (Important JSON, Keys, Certificates)
# ============================================================================
# Paths to secret files (these should be in secrets/ folder, gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
GOOGLE_CLOUD_KEY_PATH=./secrets/google-cloud-key.json
AWS_CREDENTIALS_PATH=./secrets/aws-credentials.json
KUBERNETES_CONFIG_PATH=./.kube/config

# ============================================================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL (recommended for production)
DATABASE_URL=jdbc:postgresql://localhost:5432/supremeai
DATABASE_TYPE=postgresql
DATABASE_USERNAME=supremeai_user
DATABASE_PASSWORD=your_db_password_here
DATABASE_POOL_SIZE=20
DATABASE_MAX_CONNECTIONS=100

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET_KEY=your_super_secret_jwt_key_here_min_32_chars_required_change_me
JWT_EXPIRATION_MS=86400000
SUPREMEAI_SETUP_TOKEN=your_setup_token_here_admin_only
SUPREMEAI_ADMIN_DEFAULT_PASSWORD=Admin@123456!

# ============================================================================
# DEPLOYMENT & ENVIRONMENT
# ============================================================================
APP_ENV=development
# Options: development, staging, production
APP_NAME=SupremeAI
APP_VERSION=1.0.0+1
PORT=8080

# Server Configuration
SERVER_SHUTDOWN=graceful
SERVER_SERVLET_CONTEXT_PATH=/
SERVER_COMPRESSION_ENABLED=true

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# Twilio (SMS/Voice - additional config)
TWILIO_MESSAGE_SERVICE_SID=your_twilio_message_service_sid

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@supremeai.com

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Datadog
DATADOG_API_KEY=your_datadog_key_here
DATADOG_SITE=datadoghq.com

# New Relic
NEW_RELIC_LICENSE_KEY=your_new_relic_key_here

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================================================
# COST TRACKING & BILLING
# ============================================================================
COST_TRACKING_ENABLED=true
BILLING_ALERT_THRESHOLD=1000
BILLING_EMAIL=billing@company.com

# ============================================================================
# FILE STORAGE PATHS
# ============================================================================
# Location to store generated files
OUTPUT_FILES_PATH=./output/
BUILD_FILES_PATH=./build/
LOGS_PATH=./logs/
TEMP_FILES_PATH=./tmp/

# ========================================
# IMPORTANT: SECURITY NOTES
# ========================================
# 1. Never commit your actual .env file!
# 2. Use strong, unique values for all keys  
# 3. Rotate API keys regularly (quarterly minimum)
# 4. Use GitHub Secrets for CI/CD (not .env files)
# 5. Store sensitive files in secrets/ folder
# 6. Example setup:
#    - mkdir secrets/
#    - cp /path/to/firebase-key.json secrets/
#    - cp /path/to/google-cloud-key.json secrets/
# 7. For environments:
#    - .env.local for local development
#    - .env.staging for staging/testing
#    - .env.production for production (use GitHub Secrets instead)
# 8. Review .gitignore to ensure .env* is excluded
# 9. Never paste tokens in chat/email/docs
# 10. Use least-privilege service accounts
