# SupremeAI 2.0 — Environment Configuration
# Copy this file to .env and fill in your values

# ── Core ──────────────────────────────────────────────────────────
APP_NAME="SupremeAI 2.0"
ENV=local
DEBUG=true
PORT=8000
HOST=0.0.0.0

# ── AI Providers ──────────────────────────────────────────────────
OPENROUTER_API_KEY=
HF_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
FIRECRAWL_API_KEY=
OLLAMA_URL=http://localhost:11434

# ── Video Generation ──────────────────────────────────────────────
RUNWAY_API_KEY=
KLING_API_KEY=

# ── Monitoring ────────────────────────────────────────────────────
SENTRY_DSN=

# ── Messaging / Bots ──────────────────────────────────────────────
# P0.6: @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=
# Webhook URL for production (optional, falls back to polling)
TELEGRAM_WEBHOOK_URL=

# P0.7: discord.com/developers → New App → Bot → token
DISCORD_BOT_TOKEN=

# ── GCP (Cloud Run) ───────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_NAME=supremeai-api
GCP_CLOUD_RUN_URL=
GCP_FIRESTORE_COLLECTION=verification_queue
GCP_FIRESTORE_SQLITE_PATH=
GCP_PUBSUB_TOPIC=supremeai-tasks
GCP_PUBSUB_SUBSCRIPTION=
GCP_PUBSUB_SQLITE_PATH=

# ── Multi-cloud Nodes ─────────────────────────────────────────────
# P0.1: Fill after Railway deploy
RAILWAY_URL=
# P0.2: Fill after Render deploy
RENDER_URL=
# P0.5: Fill after Cloudflare Worker deploy
CLOUDFLARE_WORKER_URL=

# Local Redis fallback
REDIS_URL=redis://localhost:6379/0

# ── Upstash Redis ─────────────────────────────────────────────────
# P0.4: upstash.com → Create Database → Redis → REST API
# REST URL format: https://xxx.upstash.io
UPSTASH_REDIS_REST_URL=
# REST Token (from Upstash dashboard)
UPSTASH_REDIS_REST_TOKEN=
# Full Redis URL (for redis-py / legacy use)
UPSTASH_REDIS_URL=

# ── Supabase PostgreSQL ───────────────────────────────────────────
# P0.3: supabase.com → New Project → Settings → Database → URI
# Format: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
SUPABASE_DATABASE_URL=

# ── Admin ─────────────────────────────────────────────────────────
SUPREMEAI_ADMIN_PASSWORD_HASH=
ADMIN_RULES_DB=data/constitutional_rules.db

# ── Limits ────────────────────────────────────────────────────────
MAX_COST_PER_TASK=0.01
