# SupremeAI Backend Environment Configuration
# Copy this file to .env and fill in your actual API keys
# DO NOT commit the .env file - it's in .gitignore

# ===== Firebase Authentication =====
# Firebase Admin Token (for local admin access)
FIREBASE_ADMIN_TOKEN=your-firebase-id-token-here

# JWT Secret for session signing (generate: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-signing-key-change-in-production

# API Encryption key (generate: openssl rand -base64 32)
API_ENCRYPTION_KEY=your-api-encryption-key-change-in-production

# ===== AI Provider API Keys =====
# StepFun (阶跃星辰) - FREE tier available (10k-50k tokens/day)
# Register at: https://platform.stepfun.com
STEPFUN_API_KEY=sf-your-stepfun-api-key-here
STEPFUN_API_KEY_1=sf-first-key-here
STEPFUN_API_KEY_2=sf-second-key-here

# Groq (Fast inference, recommended primary)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_API_KEY_1=gsk_your_first_groq_key_here
GROQ_API_KEY_2=gsk_your_second_groq_key_here
GROQ_API_KEY_DEPLOYMENT_MONITOR=gsk_your_deployment_monitor_key_here

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google AI (Gemini)
GEMINI_API_KEY=AIza-your-gemini-key-here

# DeepSeek (Coding-focused)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_KEY_1=sk-first-key-here
DEEPSEEK_API_KEY_2=sk-second-key-here

# Mistral AI
MISTRAL_API_KEY=your-mistral-key-here

# xAI (Grok)
GROK_API_KEY=your-grok-key-here

# Cohere
COHERE_API_KEY=your-cohere-key-here

# Perplexity
PERPLEXITY_API_KEY=your-perplexity-key-here

# HuggingFace
HUGGINGFACE_API_KEY=hf-your-key-here

# Kimi (Moonshot)
KIMI_API_KEY=sk-your-kimi-key-here

# ===== Firebase Configuration =====
FIREBASE_PROJECT_ID=your-firebase-project-id
JWT_SECRET=your-super-secret-jwt-signing-key-change-in-production

# ===== Database Configuration =====
# H2 (in-memory, default for local dev)
DATABASE_URL=jdbc:h2:mem:testdb
DATABASE_USERNAME=sa
DATABASE_PASSWORD=

# Redis (optional - used for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== Google Cloud (Optional - for Firestore) =====
# If using Firestore for production data storage
# GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# ===== Application Settings =====
# Server port (default 8080)
SERVER_PORT=8080

# Logging level (DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL=INFO

# ===== Rate Limiting =====
# Requests per minute per user (default: 100)
RATE_LIMIT_PER_MINUTE=100
