# ============================================================================
# SUPREMEAI CONFIGURATION FILE (.env.example)
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to git (already in .gitignore)
# 4. Use for development, testing, and local runs
# 5. For CI/CD, use GitHub Secrets instead
# ============================================================================

# ========================================
# FIREBASE CONFIGURATION
# ========================================
# Firebase project settings
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Service account (base64 encoded for GitHub Actions)
# Generate: cat service-account.json | base64
FIREBASE_SERVICE_ACCOUNT=your_base64_encoded_service_account_json

# Firebase API key (for web app)
FIREBASE_API_KEY=your-firebase-web-api-key

# ========================================
# LLM PROVIDERS
# ========================================
# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek (Alternative provider)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# ========================================
# NOTIFICATION CHANNELS
# ========================================
# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts

# Discord webhook for notifications
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR/WEBHOOK/URL
DISCORD_CHANNEL=alerts

# Twilio SMS (for critical alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email configuration (SendGrid or similar)
MAIL_API_KEY=your-sendgrid-api-key
MAIL_FROM_ADDRESS=noreply@supremeai.example.com
MAIL_FROM_NAME=SupremeAI Notifications

# ========================================
# GOOGLE CLOUD
# ========================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Cloud Build
CLOUD_BUILD_TRIGGER_ID=your-trigger-id

# ========================================
# APPLICATION CONFIG
# ========================================
# Server configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/
SPRING_PROFILES_ACTIVE=development

# Database
DATABASE_URL=jdbc:mysql://localhost:3306/supremeai
DATABASE_USERNAME=root
DATABASE_PASSWORD=your-db-password

# ========================================
# SECURITY & SECRETS
# ========================================
# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Admin API key for system operations
ADMIN_API_KEY=your-admin-api-key-for-protected-endpoints

# ========================================
# DEPLOYMENT TARGETS
# ========================================
# Render deployment
RENDER_API_KEY=your-render-api-key
RENDER_SERVICE_ID=your-render-service-id

# ========================================
# LOGGING & MONITORING
# ========================================
# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Metrics export
METRICS_EXPORT_ENABLED=true
METRICS_EXPORT_INTERVAL_SECONDS=60

# ========================================
# FEATURE FLAGS
# ========================================
# Enable/disable features
FEATURE_WEBSOCKET_ENABLED=true
FEATURE_ANALYTICS_PERSISTENCE_ENABLED=true
FEATURE_ML_INTELLIGENCE_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true

# ========================================
# DEVELOPMENT ONLY
# ========================================
# Enable verbose logging in development
DEBUG_MODE=false

# Mock external services (for testing without real credentials)
MOCK_EXTERNAL_SERVICES=false

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_USERNAME=your_github_username
GITHUB_REPO=supremeai
GITHUB_ORG=your_org_name

# ============================================================================
# ALL 10 AI API PROVIDERS (Multi-AI Consensus System)
# ============================================================================
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
GOOGLE_GEMINI_API_KEY=your_gemini_key_here
META_API_KEY=your_meta_key_here
MISTRAL_API_KEY=your_mistral_key_here
COHERE_API_KEY=your_cohere_key_here
HUGGINGFACE_API_KEY=your_huggingface_key_here
XAI_GROK_API_KEY=your_xai_key_here
DEEPSEEK_API_KEY_CONSENSUS=your_deepseek_key_here
PERPLEXITY_API_KEY=your_perplexity_key_here

# ============================================================================
# CLOUD PLATFORMS
# ============================================================================
# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=supremeai-bucket

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_TENANT_ID=your_tenant_id_here
AZURE_CLIENT_ID=your_client_id_here
AZURE_CLIENT_SECRET=your_client_secret_here

# ============================================================================
# DOCKER & CONTAINER REGISTRY
# ============================================================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password
DOCKER_IMAGE_NAME=supremeai

# ============================================================================
# SECRET FILES (Important JSON, Keys, Certificates)
# ============================================================================
# Paths to secret files (these should be in secrets/ folder, gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
GOOGLE_CLOUD_KEY_PATH=./secrets/google-cloud-key.json
AWS_CREDENTIALS_PATH=./secrets/aws-credentials.json
KUBERNETES_CONFIG_PATH=./.kube/config

# ============================================================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL (recommended for production)
DATABASE_URL=jdbc:postgresql://localhost:5432/supremeai
DATABASE_TYPE=postgresql
DATABASE_USERNAME=supremeai_user
DATABASE_PASSWORD=your_db_password_here
DATABASE_POOL_SIZE=20
DATABASE_MAX_CONNECTIONS=100

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET_KEY=your_super_secret_jwt_key_here_min_32_chars_required_change_me
JWT_EXPIRATION_MS=86400000
SUPREMEAI_SETUP_TOKEN=your_setup_token_here_admin_only
SUPREMEAI_ADMIN_DEFAULT_PASSWORD=Admin@123456!

# ============================================================================
# DEPLOYMENT & ENVIRONMENT
# ============================================================================
APP_ENV=development
# Options: development, staging, production
APP_NAME=SupremeAI
APP_VERSION=1.0.0+1
PORT=8080

# Server Configuration
SERVER_SHUTDOWN=graceful
SERVER_SERVLET_CONTEXT_PATH=/
SERVER_COMPRESSION_ENABLED=true

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# Twilio (SMS/Voice - additional config)
TWILIO_MESSAGE_SERVICE_SID=your_twilio_message_service_sid

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@supremeai.com

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Datadog
DATADOG_API_KEY=your_datadog_key_here
DATADOG_SITE=datadoghq.com

# New Relic
NEW_RELIC_LICENSE_KEY=your_new_relic_key_here

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================================================
# COST TRACKING & BILLING
# ============================================================================
COST_TRACKING_ENABLED=true
BILLING_ALERT_THRESHOLD=1000
BILLING_EMAIL=billing@company.com

# ============================================================================
# FILE STORAGE PATHS
# ============================================================================
# Location to store generated files
OUTPUT_FILES_PATH=./output/
BUILD_FILES_PATH=./build/
LOGS_PATH=./logs/
TEMP_FILES_PATH=./tmp/

# ========================================
# IMPORTANT: SECURITY NOTES
# ========================================
# 1. Never commit your actual .env file!
# 2. Use strong, unique values for all keys  
# 3. Rotate API keys regularly (quarterly minimum)
# 4. Use GitHub Secrets for CI/CD (not .env files)
# 5. Store sensitive files in secrets/ folder
# 6. Example setup:
#    - mkdir secrets/
#    - cp /path/to/firebase-key.json secrets/
#    - cp /path/to/google-cloud-key.json secrets/
# 7. For environments:
#    - .env.local for local development
#    - .env.staging for staging/testing
#    - .env.production for production (use GitHub Secrets instead)
# 8. Review .gitignore to ensure .env* is excluded
# 9. Never paste tokens in chat/email/docs
# 10. Use least-privilege service accounts
