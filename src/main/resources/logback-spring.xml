<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Properties -->
    <property name="LOG_FILE" value="logs/supremeai.log"/>
    <property name="AUDIT_LOG_FILE" value="logs/audit.log"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{correlationId}] %logger{36} - %msg%n"/>
    <property name="JSON_LOG_PATTERN" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSS'Z'} %msg%n"/>

    <!-- Console Appender (for development) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File Appender (for production) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Roll every day or when file size exceeds 100MB -->
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory> <!-- Keep 30 days of logs -->
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Async Appender (for performance) -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
    </appender>

    <!-- Audit Log Appender -->
    <appender name="AUDIT_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${AUDIT_LOG_FILE}</file>
        <encoder>
            <pattern>%msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${AUDIT_LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>90</maxHistory> <!-- Keep 90 days of audit logs -->
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Async Audit Log Appender -->
    <appender name="ASYNC_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="AUDIT_LOG"/>
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- Sentry Appender -->
    <appender name="SENTRY" class="io.sentry.logback.SentryAppender">
        <minimumEventLevel>ERROR</minimumEventLevel>
        <minimumBreadcrumbLevel>INFO</minimumBreadcrumbLevel>
    </appender>

    <!-- Cloud Logging Appender (for GCP) -->
    <appender name="CLOUD_LOGGING" class="com.google.cloud.logging.logback.LoggingAppender">
        <logLevel>INFO</logLevel>
        <includeFields>
            <field>
                <key>correlationId</key>
                <value>%X{correlationId}</value>
            </field>
        </includeFields>
        <flushSeconds>1</flushSeconds>
    </appender>

    <!-- Logger Configuration -->
    <!-- Application loggers -->
    <logger name="com.supremeai" level="DEBUG"/>
    <logger name="com.supremeai.service" level="DEBUG"/>
    <logger name="com.supremeai.security" level="DEBUG"/>
    <logger name="com.supremeai.exception" level="DEBUG"/>

    <!-- Firebase loggers -->
    <logger name="com.google.firebase" level="WARN"/>
    <logger name="com.google.cloud" level="WARN"/>

    <!-- Resilience4j loggers -->
    <logger name="io.github.resilience4j" level="INFO"/>

    <!-- Audit logger (separate appender) -->
    <logger name="AUDIT" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_AUDIT"/>
    </logger>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="SENTRY"/>
    </root>

    <!-- Profiles -->
    <!-- Development profile -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="SENTRY"/>
        </root>
    </springProfile>

    <!-- Cloud Run profile (No file logging) -->
    <springProfile name="cloud">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="SENTRY"/>
        </root>
    </springProfile>

    <!-- Production/Default profile (with file logging) -->
    <springProfile name="!cloud &amp; !dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
            <appender-ref ref="SENTRY"/>
            <appender-ref ref="CLOUD_LOGGING"/>
        </root>
    </springProfile>

</configuration>
