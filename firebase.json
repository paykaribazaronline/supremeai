{
  "firestore": {
    "rules": "config/firestore.rules",
    "indexes": "config/firestore.indexes.json"
  },
  "hosting": {
    "public": "interfaces/supremeai-studio-client/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/src/**",
      "**/scripts/**",
      "build.gradle*",
      "gradlew*",
      ".env*",
      "*.log",
      "package-lock.json"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "supremeai",
          "region": "us-central1"
        }
      },
      {
        "source": "/telemetry/**",
        "run": {
          "serviceId": "supremeai",
          "region": "us-central1"
        }
      },
      {
        "source": "/ws",
        "run": {
          "serviceId": "supremeai",
          "region": "us-central1"
        }
      },
      {
        "source": "/ws/**",
        "run": {
          "serviceId": "supremeai",
          "region": "us-central1"
        }
      },
      {
        "source": "/admin/**",
        "destination": "/index.html"
      },
      {
        "source": "/user/**",
        "destination": "/index.html"
      },
      {
        "source": "/login",
        "destination": "/index.html"
      },
      {
        "source": "/mobile/**",
        "destination": "/index.html"
      },
      {
        "source": "/visualizer",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "region": "us-central1"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8081
    },
    "functions": {
      "port": 5003
    },
    "hosting": {
      "port": 5002
    },
    "ui": {
      "port": 4001
    },
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "dataconnect": {
    "source": "dataconnect"
  }
}
