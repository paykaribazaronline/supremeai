{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/admin/",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "supremeai",
          "region": "us-central1"
        }
      },
      {
        "source": "/telemetry/**",
        "run": {
          "serviceId": "supremeai",
          "region": "us-central1"
        }
      },
      {
        "source": "/ws",
        "run": {
          "serviceId": "supremeai",
          "region": "us-central1"
        }
      },
      {
        "source": "/ws/**",
        "run": {
          "serviceId": "supremeai",
          "region": "us-central1"
        }
      },
      {
        "source": "/admin/**",
        "destination": "/index.html"
      },
      {
        "source": "/mobile/**",
        "destination": "/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=3600"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "region": "us-central1"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8081
    },
    "functions": {
      "port": 5003
    },
    "hosting": {
      "port": 5002
    },
    "ui": {
      "port": 4001
    },
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "dataconnect": {
    "source": "dataconnect"
  }
}