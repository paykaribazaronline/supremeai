# Optimized .gcloudignore for SupremeAI
# This file specifies which files should NOT be uploaded to Google Cloud Build.

# Git
.git/
.gitignore

# IDEs
.idea/
.vscode/
*.iml

# Node.js
node_modules/
npm-debug.log

# Python
__pycache__/
*.pyc

# Local Config
.env
local.properties
service-account.json

# Build directories - Build happens in Cloud Build
build/
.gradle/
.gradle-home/
.gradle-user-home/

# Include the built JAR for Docker image (CI copies it to root)
!app.jar

# Other large or unnecessary folders
supremeai-intellij-plugin/
supremeai-vscode-extension/
/docs/
/docs_new/
/colab/
/monitoring/
/admin/
/public/
/projects/
/dashboard/
/functions/
/command-hub/
/.kilo/
