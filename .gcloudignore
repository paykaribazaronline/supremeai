# Ignore everything by default
*
# Allow Gradle build files and source
!settings.gradle.kts
!build.gradle.kts
!src/**
!gradle/**
!gradlew

# Allow Dockerfile and build output
!Dockerfile

# Allow Firebase config
!.firebase/**
!firebase.json
!.firebaserc
!firebase/**

# Allow this gcloudignore itself
!.gcloudignore
!functions/**

# Re-ignore heavy folders
**/node_modules/
.gradle/
.turbo/
.git/
dashboard/node_modules/
functions/node_modules/

# Explicit hidden folder ignores
.kilo/
.docs/
.agents/
.antigravity/
.gemini/
.vscode/
.github/
.idea/
*.vsix
*.log
__pycache__/
.pytest_cache/
.env
.env.*
venv/
.venv/
.npmrc
yarn-error.log
npm-debug.log
