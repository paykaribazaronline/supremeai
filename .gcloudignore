# Ignore everything by default
*
# Allow Gradle build files and source
!settings.gradle.kts
!build.gradle.kts
!src/**
!gradle/**
!gradlew
# Allow Dockerfile and build output
!Dockerfile
!app.jar
!.gradle/build/libs/app.jar
# Allow dashboard (Firebase hosting)
!dashboard/**
# Allow public directory (Firebase hosting output)
!public/**
# Allow Firebase config
!.firebase/**
!firebase.json
!firebase/**
# Allow this gcloudignore itself
!.gcloudignore
