# Optimized .gcloudignore for SupremeAI
# This file specifies which files should NOT be uploaded to Google Cloud Build.

# Git
.git/
.gitignore

# IDEs
.idea/
.vscode/
*.iml

# Node.js
node_modules/
npm-debug.log

# Python
__pycache__/
*.pyc

# Local Config
.env
local.properties
service-account.json

# Build directories - Build happens in Cloud Build
build/
# Include the built JAR for Docker image
!build/libs/
!build/libs/app.jar

# Gradle
.gradle/
.gradle-home/
.gradle-user-home/
gradlew
gradlew.bat
gradle.properties
*.gradle

# Other large or unnecessary folders
supremeai-intellij-plugin/
supremeai-vscode-extension/
supremeai/  # This is the Flutter project folder
docs/
docs_new/
colab/
monitoring/
admin/
public/
projects/
dashboard/
functions/
command-hub/
