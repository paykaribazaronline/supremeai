// Test backend authentication flow
// IMPORTANT: This file contains sensitive credentials - DO NOT commit to git
// Copy this file to test-auth.js and fill in your actual values

const admin = require('firebase-admin');
const fetch = require('node-fetch');

// You need to copy your Firebase service account key here
const serviceAccount = require('./service-account.json');

admin.initializeApp({
  credential: admin.credential.cert(serviceAccount),
  databaseURL: 'https://supremeai-a.firebaseio.com'
});

// REPLACE WITH YOUR TEST USER CREDENTIALS
const email = 'admin@supremeai.com';
const password = 'YOUR_TEST_USER_PASSWORD';

// GET YOUR FIREBASE API KEY from Firebase Console
const apiKey = 'YOUR_FIREBASE_WEB_API_KEY_HERE';

async function testAuth() {
  try {
    // Get Firebase ID token
    const signInUrl = `https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=${apiKey}`;
    const resp = await fetch(signInUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password, returnSecureToken: true })
    });
    const data = await resp.json();
    if (!resp.ok) throw new Error(JSON.stringify(data));

    console.log('Firebase ID token acquired');

    // Exchange for backend JWT
    const backendResp = await fetch('http://localhost:8080/api/auth/firebase-login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idToken: data.idToken })
    });

    const backendData = await backendResp.json();
    console.log('Backend response:', JSON.stringify(backendData, null, 2));

    if (backendData.token) {
      // Test with token
      const healthResp = await fetch('http://localhost:8080/api/health', {
        headers: { 'Authorization': `Bearer ${backendData.token}` }
      });
      console.log('Health check status:', healthResp.status);
      console.log('Health check body:', await healthResp.text());
    }
  } catch (err) {
    console.error('Error:', err.message);
  }
}

testAuth();