{
  "models": [
    {
      "title": "SupremeAI-Llama",
      "provider": "ollama",
      "model": "llama3.2:70b",
      "apiBase": "http://localhost:11434",
      "capabilities": ["code-gen", "bangla-utf8"]
    },
    {
      "title": "SupremeAI-Grok",
      "provider": "openai",
      "apiKey": "${env:GROK_API_KEY}",
      "apiBase": "https://api.x.ai/v1",
      "model": "grok-2"
    }
  ],
  "context": {
    "provider": "github",
    "repository": "paykaribazaronline/supremeai"
  },
  "workflows": [
    {
      "name": "supremeai-agent",
      "steps": [
        {
          "name": "X-Builder Analysis",
          "model": "SupremeAI-Llama",
          "prompt": "Analyze this Spring Boot code for SupremeAI compliance..."
        }
      ]
    }
  ]
}
