# Gitingest Environment Variables
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_HOSTS=["*"]

# GitHub
GITHUB_TOKEN=ghp_...  # Optional, for higher rate limits

# S3/MinIO Cache (optional)
S3_ENABLED=false
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=gitingest-cache
S3_USE_SSL=false

# Logging
LOG_FORMAT=json  # json or text
LOG_LEVEL=INFO
SENTRY_DSN=https://...
POSTHOG_API_KEY=phc_...

# Limits
MAX_FILE_SIZE=10485760  # 10 MB in bytes
MAX_DIR_DEPTH=20
MAX_FILES=10000
MAX_TOTAL_SIZE=524288000  # 500 MB in bytes
CLONE_TIMEOUT=60  # seconds

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Prometheus Metrics
METRICS_PORT=9090
