# Copy this file to monitoring/.env and fill in real values.
# monitoring/.env is git-ignored — NEVER commit real secrets.

# ── Grafana local admin (fallback when Google OAuth is disabled) ──────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Google OAuth via Firebase Identity Platform ───────────────────────────
# HOW TO GET THESE VALUES:
#   1. Go to https://console.firebase.google.com → Project supremeai-a
#   2. Project Settings → General → Your apps → Web app
#   3. For OAuth client: Google Cloud Console → APIs & Services → Credentials
#      → Create OAuth 2.0 Client ID (type: Web application)
#   4. Add authorized redirect URI: http://localhost:3000/login/google
#      (or your production Grafana URL + /login/google)
#
# Set GF_AUTH_GOOGLE_ENABLED=true to activate Firebase/Google login.
# When enabled, users sign in with their Google account (same identity as Firebase).
GF_AUTH_GOOGLE_ENABLED=false
GF_GOOGLE_CLIENT_ID=YOUR_FIREBASE_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
GF_GOOGLE_CLIENT_SECRET=YOUR_FIREBASE_GOOGLE_OAUTH_CLIENT_SECRET

# Email address of the Grafana Admin (mapped from Firebase auth user)
GF_GOOGLE_ADMIN_EMAIL=admin@yourdomain.com

# Restrict login to one Google Workspace domain (leave blank = any Google account)
GF_GOOGLE_ALLOWED_DOMAINS=

# Allow new Google users to be auto-created in Grafana
GF_AUTH_GOOGLE_ALLOW_SIGN_UP=true

# Public URL of Grafana — must match OAuth redirect URI in Firebase/Google Console
GF_SERVER_ROOT_URL=http://localhost:3000

# ── Prometheus scrape target ──────────────────────────────────────────────
#   Docker Desktop (Windows / Mac) -> host.docker.internal:8080
#   Linux host (bridge network)    -> 172.17.0.1:8080
#   Same docker-compose network    -> supremeai-app:8080
SUPREMEAI_APP_HOST=host.docker.internal:8080
