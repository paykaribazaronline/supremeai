  "knowledgeEntries": [
    {
      "id": "ke-2026-001",
      "topic": "Spring Boot 3 + Firestore Reactive Stream",
      "pattern": "When a Firestore reactive query blocks a virtual thread, the thread pool saturates under load",
      "solution": "Use FirestoreReactiveRepository inside Mono/Flux chains. Avoid blocking subscribers. Configure reactor.scheduler.max_auto_create_threads for burst traffic.",
      "sourceProvider": "qwen-coder",
      "confidenceScore": 0.94,
      "createdAt": "2026-05-10T14:00:00"
    },
    {
      "id": "ke-2026-002",
      "topic": "Bengali BN.json Key Mapping",
      "pattern": "A UI label uses key 'chat.send' but bn.json only has 'send_message'",
      "solution": "Ensure i18n keys match between template and bn.json. Run automated i18n key lint before frontend PR.",
      "sourceProvider": "llama-3-1",
      "confidenceScore": 0.97,
      "createdAt": "2026-05-12T09:30:00"
    },
    {
      "id": "ke-2026-003",
      "topic": "AI Fallback Chain Latency Spikes",
      "pattern": "Primary provider times out then fallback also times out — double latency window paralyzes user",
      "solution": "Set per-attempt timeout at 10s. On primary fail, try fallback immediately (no retry on primary). Log both attempts in activity_logs.",
      "sourceProvider": "deepseek-pro",
      "confidenceScore": 0.89,
      "createdAt": "2026-05-14T18:15:00"
    },
    {
      "id": "ke-2026-004",
      "topic": "Flutter Riverpod Provider Scope Leak",
      "pattern": "ChatScreen async provider stays subscribed after navigation, leaking Firestore streams",
      "solution": "Wrap provider in `ref.onDispose(() => stream.close())`. Use `autoDispose` modifier in riverpod_generator.",
      "sourceProvider": "phi-3",
      "confidenceScore": 0.86,
      "createdAt": "2026-05-13T11:00:00"
    },
    {
      "id": "ke-2026-005",
      "topic": "Firestore Composite Index Missing",
      "pattern": "Query fails with 'no matching index' error after adding a new filter field in existing collection group query",
      "solution": "Copy the Firestore index creation URL from the error message and run it in console, or add index entry to firestore.indexes.json before deploying.",
      "sourceProvider": "qwen-coder",
      "confidenceScore": 0.98,
      "createdAt": "2026-05-15T16:45:00"
    }
  ],

