  "workflowDefinitions": [
    {
      "id": "wf-code-review",
      "name": "Automated Code Review",
      "description": "When a PR is opened, trigger AI agents to review code, post comments, and approve lane merges",
      "trigger": "webhook",
      "steps": [
        {"step": 1, "action": "fetch_pr_diff", "timeoutSeconds": 30},
        {"step": 2, "action": "agent_analyze", "agentId": "agent-coder", "timeoutSeconds": 120},
        {"step": 3, "action": "vote_consensus", "agents": ["agent-coder", "agent-reasoner"], "timeoutSeconds": 60},
        {"step": 4, "action": "post_review_comments", "timeoutSeconds": 30}
      ],
      "outputs": {"approvalRequired": true, "requiredVotes": 2}
    },
    {
      "id": "wf-auto-heal",
      "name": "Self-Healing Recovery",
      "description": "Automatically diagnose failures via HealingEvent entries and attempt provider rotation or config reload",
      "trigger": "scheduled",
      "steps": [
        {"step": 1, "action": "collect_recent_errors", "timeoutSeconds": 15},
        {"step": 2, "action": "analyze_failure_pattern", "agentId": "agent-reasoner", "timeoutSeconds": 60},
        {"step": 3, "action": "apply_remediation", "timeoutSeconds": 45},
        {"step": 4, "action": "log_healing_event", "timeoutSeconds": 10}
      ],
      "outputs": {"maxAttempts": 3, "escalateToAdmin": true}
    },
    {
      "id": "wf-daily-knowledge",
      "name": "Daily Knowledge Learning",
      "description": "Every 24h scheduler reviews chat sessions for new patterns and seeds them into knowledge_entries",
      "trigger": "scheduled",
      "steps": [
        {"step": 1, "action": "fetch_recent_chat_sessions", "sinceHours": 24},
        {"step": 2, "action": "extract_patterns", "agentId": "agent-chat", "timeoutSeconds": 180},
        {"step": 3, "action": "save_to_knowledge_entries", "timeoutSeconds": 30}
      ],
      "outputs": {"minConfidenceToStore": 0.85, "runIntervalHours": 24}
    }
  ],

