rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tier == 'ADMIN';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // System Config: All authenticated can read (for app init), but only Admin can write
    match /system_configs/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // API Providers: Admin only for writing, all authenticated for reading
    match /api_providers/{providerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Users: Owner can read/write their own profile, Admin can do anything
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated(); // Allow initial registration
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    // activity_logs: Admin only for browsing, authenticated can create
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Reasoning Logs: Authenticated can read (if part of task), Admin can read all
    match /reasoning_logs/{logId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Default rules for other collections
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
