# Google Cloud Build ignore rules for backend
# Keep the backend build context small and avoid sending editor/cache files.
# Local supabase/db artifacts and secrets should not be uploaded to Cloud Build.

.git
.gitignore
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

data/
*.db
*.sqlite3
*.sqlite
service-account.json
.env*

# Build artifacts and docs
*.egg-info
*.md
LICENSE

# Non-runtime artifacts
tests/
logs/

# Ignore sibling or monorepo directories if build is run from root
../apps/
../packages/
../tools/
