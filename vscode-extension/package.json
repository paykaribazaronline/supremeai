{
  "name": "supremeai-vscode",
  "displayName": "SupremeAI",
  "description": "SupremeAI VS Code Extension for Android App Generation and AI Code Review",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:supremeai.generateApp",
    "onCommand:supremeai.codeReview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "supremeai.generateApp",
        "title": "SupremeAI: Generate Android App"
      },
      {
        "command": "supremeai.codeReview",
        "title": "SupremeAI: AI Code Review"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && tsc -p test",
    "test": "node test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.3",
    "@types/node": "18.x",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
