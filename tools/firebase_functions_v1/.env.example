# SupremeAI Local-First Mode Configuration
# NO EXTERNAL AI API KEYS REQUIRED
# System operates in fully offline mode

# External integrations are disabled by default
ENABLE_EXTERNAL_API=false
ENABLE_BROWSER_SIDECAR=false

# Local AI Configuration (optional)
OLLAMA_BASE_URL=http://localhost:11434
AIRLLM_SIDECAR_URL=http://localhost:8081

# Browser Automation URL (for local Playwright server)
BROWSER_AUTOMATION_URL=http://localhost:3001

# Timeouts for local operations
EXTERNAL_TIMEOUT_MS=4000
SCRAPE_TIMEOUT_MS=30000