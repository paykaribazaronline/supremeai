      "packageDescription": "Real-time code analysis, learning, and AI assistance with SupremeAI Core Engine"
    },
    "bn": {
      "packageDisplayName": "সুপ্রিমএআই - এআই-চালিত ডেভেলপমেন্ট সহায়ক",
      "packageDescription": "সুপ্রিমএআই কোর ইঞ্জিনের সাথে রিয়েল-টাইম কোড বিশ্লেষণ, শিখুন এবং এআই সহায়তা"
    }
  },
  "keywords": [
    "AI",
    "Code Assistant",
    "Learning",
    "SupremeAI",
    "Auto-Completion",
    "Error Detection",
    "CodeFlow",
    "Analysis",
    "Code Generation",
    "Refactoring"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "supremeai.login",
        "title": "SupremeAI: Login",
        "titled": {
          "default": "SupremeAI: Login",
          "bn": "সুপ্রিমএআই: লগইন করুন"
        }
      },
      {
        "command": "supremeai.loginAsGuest",
        "title": "SupremeAI: Login as Guest",
        "titled": {
          "default": "SupremeAI: Login as Guest",
          "bn": "সুপ্রিমএআই: অতিথি হিসেবে লগইন করুন"
        }
      },
      {
        "command": "supremeai.logout",
        "title": "SupremeAI: Logout",
        "titled": {
          "default": "SupremeAI: Logout",
          "bn": "সুপ্রিমএআই: লগআউট করুন"
        }
      },
      {
