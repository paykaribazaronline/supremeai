{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".indexOn": ["username", "email"],
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || auth.token.admin === true)",
        ".write": "auth != null && (auth.token.admin === true || ($uid === auth.uid && (!newData.child('isAdmin').exists() || newData.child('isAdmin').val() === false) && (!newData.child('role').exists() || newData.child('role').val() === 'user' || newData.child('role').val() === 'viewer' || newData.child('role').val() === 'member')))",

        "isAdmin": {
          ".write": "auth != null && auth.token.admin === true"
        },
        "role": {
          ".write": "auth != null && auth.token.admin === true"
        },
        "permissions": {
          ".write": "auth != null && auth.token.admin === true"
        },
        "password": {
          ".read": "auth != null && auth.token.admin === true",
          ".write": "auth != null && auth.token.admin === true"
        },
        "passwordHash": {
          ".read": "auth != null && auth.token.admin === true",
          ".write": "auth != null && auth.token.admin === true"
        }
      }
    },

    "notifications": {
      "$notificationId": {
        ".read": "auth != null && (data.child('recipient').val() === auth.uid || auth.token.admin === true)",
        ".write": "auth != null && auth.token.admin === true"
      }
    },

    "projects": {
      "$projectId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.admin === true",

        "chat": {
          "$chatId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },

    "requirements": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin === true"
    },

    "config": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.admin === true"
    },

    "security": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "intelligence": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "evolution": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "ai_dead_letter_queue": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "system_learnings": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "learnings": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "providers": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      "$providerId": {
        "apiKey": {
          ".read": false,
          ".write": false
        }
      }
    },

    "provider_secrets": {
      ".read": false,
      ".write": false
    },

    "audit_logs": {
      ".indexOn": ["timestamp", "action", "providerId"],
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "work_history": {
      ".indexOn": ["timestamp", "agentId", "status"],
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "assignments": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "quota": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "agent_executions": {
      ".indexOn": ["timestamp", "agentId", "taskType"],
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "consensus_history": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "chat_history": {
      ".indexOn": ["timestamp", "sender"],
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "vpn_configs": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "deployment_history": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "self_healing_events": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "metrics_snapshots": {
      ".indexOn": ["timestamp"],
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },

    "timeline_events": {
      ".indexOn": ["timestamp", "type"],
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    }
  }
}
